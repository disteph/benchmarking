#!/bin/bash

set -e

# directory of the script
dir=$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )

# get the option
option=$1

# yices2 directory
yices2_dir="$dir/yices2"
yicesqs_dir="$dir/yicesQS"
yices2_ocaml_bindings_dir="$dir/yices2_ocaml_bindings"

export LD_LIBRARY_PATH=$dir/install/lib:/usr/local/lib
export LDFLAGS="-L/space-1/yices/sgl_exp/lib/lib"

mkdir -p "$dir/install"

# descend into correct directory to get git tagging
case $option in
    string|string-smt2)
        cd "$yices2_ocaml_bindings_dir"
        ;;
    qs)
        cd "$yicesqs_dir"
        ;;
    *)
	cd "$yices2_dir"
	;;
esac

# Constructing a tag for version found in that directory

status=$( git status -s | grep "M " || true )

if [ -z "$status" ]
then
    modified=""
else
    modified="_modified_$( date --iso-8601=minutes | sed s/T/_/g)"
fi

branch=$( git status -bs | head -1 | sed 's/##\ \(.*\)\.\.\.\(.*\)$/\1/' )
base=$( git log -n 1 --format=format:"%aI_%h" | sed s/"T"/_/g )

if [ -z "$( echo $branch | grep "##" )" ]
then
    tag=$base$modified"_"$branch
else
    tag=$base$modified"_nobranch"
fi

# Initialising parts of filename
opt=""
prefix=""
suffix=""

clean_git_hash() {
    repo_dir=$1
    repo_name=$2

    if [ ! -d "$repo_dir" ]; then
	echo "$repo_name directory not found: $repo_dir" >&2
	exit 1
    fi

    if ! git -C "$repo_dir" rev-parse --git-dir >/dev/null 2>&1; then
	echo "$repo_name directory is not a git repository: $repo_dir" >&2
	exit 1
    fi

    repo_status=$( git -C "$repo_dir" status --porcelain --ignore-submodules=none )
    if [ -n "$repo_status" ]; then
	echo "$repo_name directory has uncommitted changes:" >&2
	echo "$repo_status" >&2
	exit 1
    fi

    git -C "$repo_dir" rev-parse --short HEAD
}

make_wrapper() {
    wrapper=$1
    shift
    {
        echo "#!/bin/bash"
        echo "exec \"$dir/install/$filename\" $* \"\$@\""
    } > "$dir/install/$wrapper"
    chmod a+x "$dir/install/$wrapper"
}

case $option in 
    debug)
        MODE=debug make
        suffix="-debug"
        bin_dir="x86_64-pc-linux-gnu-debug/bin"
	bin="$yices2_dir/build/$bin_dir/yices_smt2"
        ;;
    debug-check)
        MODE=debug make
        suffix="-debug-check"
        bin_dir="x86_64-pc-linux-gnu-debug/bin"
        bin="$yices2_dir/build/$bin_dir/yices_smt2"
	opt=" --trace mcsat::bv::conflict::check --trace mcsat::propagation::check --trace mcsat::bv::rewrite::check"
        ;;
    static)
        make static-bin
        suffix="-static"
        bin_dir="x86_64-pc-linux-gnu-release/static_bin"
        bin="$yices2_dir/build/$bin_dir/yices_smt2"
	;;
    api)
        make
	make install
        bin=$(mktemp) || exit 1
	echo "$tag" > $bin
	tag="api_version"
        ;;
    qs)
	bindings_hash=$( clean_git_hash "$yices2_ocaml_bindings_dir" "Yices2 OCaml bindings" )
	make
	prefix="yicesQS-"
	suffix="-$bindings_hash"
	if [ -x "$yicesqs_dir/main.exe" ]; then
	    bin="$yicesqs_dir/main.exe"
	else
	    bin="$yicesqs_dir/_build/default/src/main.exe"
	fi
	;;
    string|string-smt2)
	make
	prefix="yices_string_smt2-"
	bin="$yices2_ocaml_bindings_dir/yices_string_smt2.exe"
	if [ ! -x "$bin" ]; then
	    echo "Expected executable not found: $bin" >&2
	    exit 1
	fi
	;;
    *)
	make
        bin_dir="x86_64-pc-linux-gnu-release/bin"
	bin="$yices2_dir/build/$bin_dir/yices_smt2"
	;;
esac

filename="$prefix$tag$suffix"

echo $filename
cp "$bin" "$dir/install/$filename"

# Adding variants of exectuable files

case $option in
    api)
	echo "Done installing Yices API"
	;;
    qs)
	echo "Done with QS"
	make_wrapper "$filename-mcsat" "-mcsat"
	make_wrapper "$filename-cdclT" "-cdclT"
	make_wrapper "$filename-cdclT-cadical" "-cdclT -delegate cadical"
	make_wrapper "$filename-cdclT-cryptominisat" "-cdclT -delegate cryptominisat"
	make_wrapper "$filename-auto" "-auto_portfolio 1200"
	;;
    string|string-smt2)
	echo "Done installing yices_string_smt2"
	;;
    *)
	echo "#!/bin/bash
$dir/install/$filename --mcsat $opt \$@" > "$dir/install/$filename.mcsat"
	chmod a+x "$dir/install/$filename.mcsat"
	echo "#!/bin/bash
$dir/install/$filename --mcsat --stats $opt \$@" > "$dir/install/$filename.stats.mcsat"
        chmod a+x "$dir/install/$filename.stats.mcsat"
	;;
esac
